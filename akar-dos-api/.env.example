# AKAR DOS API — environment template. Copy to .env and fill values. NEVER commit .env.
# Local dev uses the standard docker-compose Postgres on port 5433.
DATABASE_URL="postgresql://akar:akar_dev_password@localhost:5433/akar_dos?schema=public"
REDIS_URL="redis://localhost:6379"

# JWT — use >=64 char random strings in production. Never commit real secrets.
JWT_SECRET="change-me-in-production-use-64-char-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret-64-char-random"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"

# Google Sheets (later milestone). Empty => fixture mode.
GOOGLE_SHEET_ID=""
GOOGLE_SERVICE_ACCOUNT_JSON=""
SHEET_SYNC_FIXTURE_DIR="fixtures/sheets"

# Dealer branding
DEALER_NAME="AKAR Motors"
DEALER_ADDRESS="Jaipur, Rajasthan"
DEALER_GSTIN=""
