# SmartDeal CRM — Docker Compose Example
# Full development stack: all microservices + infrastructure
# Usage: docker-compose -f docker-compose.yml.example up -d
#
# Prerequisites:
#   - Copy .env.example to .env and fill in credentials
#   - Docker Desktop or Docker Engine >= 24.x

version: "3.9"

# ─── Networks ─────────────────────────────────────────────────────────────────
networks:
  smartdeal-network:
    driver: bridge

# ─── Volumes ──────────────────────────────────────────────────────────────────
volumes:
  postgres-data:
  redis-data:
  elasticsearch-data:
  grafana-data:
  prometheus-data:

# ─── Services ─────────────────────────────────────────────────────────────────
services:

  # ── Infrastructure ──────────────────────────────────────────────────────────

  postgres:
    image: postgres:15-alpine
    container_name: smartdeal-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: smartdeal_dev
      POSTGRES_USER: smartdeal_app
      POSTGRES_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    networks:
      - smartdeal-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U smartdeal_app -d smartdeal_dev"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: smartdeal-redis
    restart: unless-stopped
    command: redis-server --requirepass ${REDIS_PASSWORD:-dev_redis_password}
    ports:
      - "6379:6379"
    volumes:
      - redis-data:/data
    networks:
      - smartdeal-network
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "${REDIS_PASSWORD:-dev_redis_password}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  elasticsearch:
    image: elasticsearch:8.12.0
    container_name: smartdeal-elasticsearch
    restart: unless-stopped
    environment:
      - discovery.type=single-node
      - ES_JAVA_OPTS=-Xms512m -Xmx512m
      - xpack.security.enabled=false
    ports:
      - "9200:9200"
    volumes:
      - elasticsearch-data:/usr/share/elasticsearch/data
    networks:
      - smartdeal-network
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:9200/_cluster/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5

  kibana:
    image: kibana:8.12.0
    container_name: smartdeal-kibana
    restart: unless-stopped
    ports:
      - "5601:5601"
    environment:
      ELASTICSEARCH_HOSTS: http://elasticsearch:9200
    depends_on:
      elasticsearch:
        condition: service_healthy
    networks:
      - smartdeal-network

  prometheus:
    image: prom/prometheus:latest
    container_name: smartdeal-prometheus
    restart: unless-stopped
    ports:
      - "9090:9090"
    volumes:
      - prometheus-data:/prometheus
    networks:
      - smartdeal-network

  grafana:
    image: grafana/grafana:latest
    container_name: smartdeal-grafana
    restart: unless-stopped
    ports:
      - "3100:3000"
    environment:
      GF_SECURITY_ADMIN_PASSWORD: ${GRAFANA_ADMIN_PASSWORD:-admin}
    volumes:
      - grafana-data:/var/lib/grafana
    depends_on:
      - prometheus
    networks:
      - smartdeal-network

  # ── API Gateway ─────────────────────────────────────────────────────────────

  api-gateway:
    build:
      context: ../../
      dockerfile: src/api-gateway/Dockerfile
    container_name: smartdeal-api-gateway
    restart: unless-stopped
    ports:
      - "8080:8080"
    environment:
      NODE_ENV: development
      PORT: 8080
      JWT_PUBLIC_KEY: ${JWT_PUBLIC_KEY}
      ALLOWED_ORIGINS: ${ALLOWED_ORIGINS:-http://localhost:4000}
      AUTH_SERVICE_URL: http://auth-service:3001
      LEAD_SERVICE_URL: http://lead-service:3002
      QUOTATION_SERVICE_URL: http://quotation-service:3003
      BOOKING_SERVICE_URL: http://booking-service:3004
      FINANCE_SERVICE_URL: http://finance-service:3005
      INSURANCE_SERVICE_URL: http://insurance-service:3006
      BILLING_SERVICE_URL: http://billing-service:3007
      STOCK_SERVICE_URL: http://stock-service:3008
      PDI_SERVICE_URL: http://pdi-service:3009
      DELIVERY_SERVICE_URL: http://delivery-service:3010
      NOTIFICATION_SERVICE_URL: http://notification-service:3011
      ANALYTICS_SERVICE_URL: http://analytics-service:3012
      LEGACY_QUOTATION_URL: http://host.docker.internal:3000  # Existing index.js
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
    depends_on:
      redis:
        condition: service_healthy
    networks:
      - smartdeal-network

  # ── Microservices ────────────────────────────────────────────────────────────

  auth-service:
    build:
      context: ../../
      dockerfile: src/services/auth-service/Dockerfile
    container_name: smartdeal-auth-service
    restart: unless-stopped
    expose:
      - "3001"
    environment:
      NODE_ENV: development
      PORT: 3001
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      JWT_PRIVATE_KEY: ${JWT_PRIVATE_KEY}
      JWT_PUBLIC_KEY: ${JWT_PUBLIC_KEY}
      JWT_ACCESS_TOKEN_TTL: 900
      JWT_REFRESH_TOKEN_TTL: 604800
      WHATSAPP_PHONE_ID: ${WHATSAPP_PHONE_ID}
      WHATSAPP_ACCESS_TOKEN: ${WHATSAPP_ACCESS_TOKEN}
      ENCRYPTION_KEY: ${ENCRYPTION_KEY}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - smartdeal-network

  lead-service:
    build:
      context: ../../
      dockerfile: src/services/lead-service/Dockerfile
    container_name: smartdeal-lead-service
    restart: unless-stopped
    expose:
      - "3002"
    environment:
      NODE_ENV: development
      PORT: 3002
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - smartdeal-network

  quotation-service:
    build:
      context: ../../
      dockerfile: src/services/quotation-service/Dockerfile
    container_name: smartdeal-quotation-service
    restart: unless-stopped
    expose:
      - "3003"
    environment:
      NODE_ENV: development
      PORT: 3003
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      GOOGLE_SHEETS_API_KEY: ${GOOGLE_SHEETS_API_KEY}
      STOCK_SHEET_ID: ${STOCK_SHEET_ID}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - smartdeal-network

  booking-service:
    build:
      context: ../../
      dockerfile: src/services/booking-service/Dockerfile
    container_name: smartdeal-booking-service
    restart: unless-stopped
    expose:
      - "3004"
    environment:
      NODE_ENV: development
      PORT: 3004
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      AWS_REGION: ${AWS_REGION:-ap-south-1}
      AWS_ACCESS_KEY_ID: ${AWS_ACCESS_KEY_ID}
      AWS_SECRET_ACCESS_KEY: ${AWS_SECRET_ACCESS_KEY}
      AWS_S3_BUCKET: ${AWS_S3_BUCKET:-smartdeal-documents-dev}
      RAZORPAY_KEY_ID: ${RAZORPAY_KEY_ID}
      RAZORPAY_KEY_SECRET: ${RAZORPAY_KEY_SECRET}
      ENCRYPTION_KEY: ${ENCRYPTION_KEY}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - smartdeal-network

  finance-service:
    build:
      context: ../../
      dockerfile: src/services/finance-service/Dockerfile
    container_name: smartdeal-finance-service
    restart: unless-stopped
    expose:
      - "3005"
    environment:
      NODE_ENV: development
      PORT: 3005
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      TATA_CAPITAL_DEALER_CODE: ${TATA_CAPITAL_DEALER_CODE}
      TATA_CAPITAL_API_KEY: ${TATA_CAPITAL_API_KEY}
      HDFC_DSA_CODE: ${HDFC_DSA_CODE}
      HDFC_API_KEY: ${HDFC_API_KEY}
      ENCRYPTION_KEY: ${ENCRYPTION_KEY}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - smartdeal-network

  insurance-service:
    build:
      context: ../../
      dockerfile: src/services/insurance-service/Dockerfile
    container_name: smartdeal-insurance-service
    restart: unless-stopped
    expose:
      - "3006"
    environment:
      NODE_ENV: development
      PORT: 3006
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      TATAIG_API_KEY: ${TATAIG_API_KEY}
      BAJAJ_API_KEY: ${BAJAJ_API_KEY}
      ICICI_LOMBARD_API_KEY: ${ICICI_LOMBARD_API_KEY}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - smartdeal-network

  billing-service:
    build:
      context: ../../
      dockerfile: src/services/billing-service/Dockerfile
    container_name: smartdeal-billing-service
    restart: unless-stopped
    expose:
      - "3007"
    environment:
      NODE_ENV: development
      PORT: 3007
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      AWS_S3_BUCKET: ${AWS_S3_BUCKET:-smartdeal-documents-dev}
      GST_PORTAL_USERNAME: ${GST_PORTAL_USERNAME}
      GST_PORTAL_PASSWORD: ${GST_PORTAL_PASSWORD}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - smartdeal-network

  stock-service:
    build:
      context: ../../
      dockerfile: src/services/stock-service/Dockerfile
    container_name: smartdeal-stock-service
    restart: unless-stopped
    expose:
      - "3008"
    environment:
      NODE_ENV: development
      PORT: 3008
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      GOOGLE_SHEETS_API_KEY: ${GOOGLE_SHEETS_API_KEY}
      STOCK_SHEET_ID: ${STOCK_SHEET_ID}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - smartdeal-network

  pdi-service:
    build:
      context: ../../
      dockerfile: src/services/pdi-service/Dockerfile
    container_name: smartdeal-pdi-service
    restart: unless-stopped
    expose:
      - "3009"
    environment:
      NODE_ENV: development
      PORT: 3009
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      AWS_REGION: ${AWS_REGION:-ap-south-1}
      AWS_ACCESS_KEY_ID: ${AWS_ACCESS_KEY_ID}
      AWS_SECRET_ACCESS_KEY: ${AWS_SECRET_ACCESS_KEY}
      AWS_S3_BUCKET: ${AWS_S3_BUCKET:-smartdeal-documents-dev}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - smartdeal-network

  delivery-service:
    build:
      context: ../../
      dockerfile: src/services/delivery-service/Dockerfile
    container_name: smartdeal-delivery-service
    restart: unless-stopped
    expose:
      - "3010"
    environment:
      NODE_ENV: development
      PORT: 3010
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      AWS_REGION: ${AWS_REGION:-ap-south-1}
      AWS_ACCESS_KEY_ID: ${AWS_ACCESS_KEY_ID}
      AWS_SECRET_ACCESS_KEY: ${AWS_SECRET_ACCESS_KEY}
      AWS_S3_BUCKET: ${AWS_S3_BUCKET:-smartdeal-documents-dev}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - smartdeal-network

  notification-service:
    build:
      context: ../../
      dockerfile: src/services/notification-service/Dockerfile
    container_name: smartdeal-notification-service
    restart: unless-stopped
    expose:
      - "3011"
    environment:
      NODE_ENV: development
      PORT: 3011
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      WHATSAPP_PHONE_ID: ${WHATSAPP_PHONE_ID}
      WHATSAPP_ACCESS_TOKEN: ${WHATSAPP_ACCESS_TOKEN}
      WHATSAPP_WEBHOOK_VERIFY_TOKEN: ${WHATSAPP_WEBHOOK_VERIFY_TOKEN}
      AWS_REGION: ${AWS_REGION:-ap-south-1}
      AWS_SES_FROM_EMAIL: ${AWS_SES_FROM_EMAIL:-noreply@akar-motors.in}
    depends_on:
      redis:
        condition: service_healthy
    networks:
      - smartdeal-network

  analytics-service:
    build:
      context: ../../
      dockerfile: src/services/analytics-service/Dockerfile
    container_name: smartdeal-analytics-service
    restart: unless-stopped
    expose:
      - "3012"
    environment:
      NODE_ENV: development
      PORT: 3012
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: smartdeal_dev
      DB_USER: smartdeal_app
      DB_PASSWORD: ${DB_PASSWORD:-dev_password_change_me}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-dev_redis_password}
      ELASTICSEARCH_NODE: http://elasticsearch:9200
    depends_on:
      postgres:
        condition: service_healthy
      elasticsearch:
        condition: service_healthy
    networks:
      - smartdeal-network

# ─── Usage ────────────────────────────────────────────────────────────────────
# Start all services:
#   docker-compose -f docker-compose.yml.example up -d
#
# Start only infrastructure (for local service development):
#   docker-compose -f docker-compose.yml.example up -d postgres redis elasticsearch
#
# View logs:
#   docker-compose -f docker-compose.yml.example logs -f api-gateway
#
# Stop all:
#   docker-compose -f docker-compose.yml.example down
#
# Stop and remove volumes (WARNING: deletes all data):
#   docker-compose -f docker-compose.yml.example down -v
